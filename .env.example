# VibeGraph Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AWS CREDENTIALS (Required for Real AWS Bedrock)
# =============================================================================
# Get these from AWS IAM Console after creating a user with Bedrock permissions
# Leave as 'test' to use LocalStack (mock AWS services)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# =============================================================================
# AWS BEDROCK MODELS
# =============================================================================
# Text Generation (Claude)
CLAUDE_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Text Embeddings (Titan)
TITAN_MODEL=amazon.titan-embed-text-v2:0

# Image Generation (choose one or both)
TITAN_IMAGE_MODEL=amazon.titan-image-generator-v1
SDXL_MODEL=stability.stable-diffusion-xl-v1

# =============================================================================
# AWS ENDPOINTS
# =============================================================================
# For LocalStack (local development with mock AWS):
# BEDROCK_ENDPOINT=http://localstack:4566
# DYNAMODB_ENDPOINT=http://dynamodb-local:8000

# For Real AWS (comment out the above and use these):
# BEDROCK_ENDPOINT=  (leave empty to use real AWS)
# DYNAMODB_ENDPOINT=  (leave empty to use real AWS)

# =============================================================================
# DYNAMODB TABLES
# =============================================================================
USERS_TABLE=vibegraph-users
SESSIONS_TABLE=vibegraph-sessions
CACHE_TABLE=vibegraph-embedding-cache

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# =============================================================================
# FRONTEND
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_ENV=development

# =============================================================================
# CORS (for local development)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# NOTES
# =============================================================================
# To use REAL AWS Bedrock:
# 1. Set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY to your real credentials
# 2. Comment out or remove BEDROCK_ENDPOINT in docker-compose.override.yml
# 3. Ensure Bedrock models are enabled in your AWS account
# 4. See AWS_BEDROCK_SETUP.md for detailed instructions
#
# To use LocalStack (mock AWS):
# 1. Keep AWS credentials as 'test'
# 2. Ensure BEDROCK_ENDPOINT=http://localstack:4566 in docker-compose.override.yml
# 3. Note: LocalStack free tier does NOT support Bedrock runtime
