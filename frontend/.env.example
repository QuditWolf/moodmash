# VibeGraph Frontend Environment Configuration
# Copy this file to .env for local development

# API Configuration
# Base URL for the VibeGraph backend API
# Development: http://localhost:8000
# Docker: http://backend-api:8000
# Production: https://api.vibegraph.com
VITE_VIBEGRAPH_API_URL=http://localhost:8000

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# Environment
# Options: development, staging, production
VITE_ENV=development

# Feature Flags
# Enable dark mode toggle in UI
VITE_ENABLE_DARK_MODE=true

# Enable social features (matching, analytics)
VITE_ENABLE_SOCIAL_FEATURES=true

# Logging
# Options: debug, info, warn, error
VITE_LOG_LEVEL=info

# Analytics (optional)
# Google Analytics tracking ID
VITE_ANALYTICS_ID=

# Sentry DSN for error tracking (optional)
VITE_SENTRY_DSN=
