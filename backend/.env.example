# VibeGraph Backend Environment Configuration
# Copy this file to .env for local development

# ============================================
# AWS Configuration
# ============================================

# AWS Region for all services
AWS_REGION=us-east-1

# AWS Credentials
# For local development with LocalStack/DynamoDB Local, use test credentials
# For production, use IAM roles or proper credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ============================================
# DynamoDB Configuration
# ============================================

# DynamoDB endpoint URL
# Local development: http://localhost:8001 or http://dynamodb-local:8000 (Docker)
# Production: leave empty to use AWS default
DYNAMODB_ENDPOINT=http://localhost:8001

# DynamoDB table names
USERS_TABLE=vibegraph-users
SESSIONS_TABLE=vibegraph-sessions
CACHE_TABLE=vibegraph-embedding-cache

# ============================================
# AWS Bedrock Configuration
# ============================================

# Bedrock endpoint URL
# Local development with LocalStack: http://localhost:4566 or http://localstack:4566 (Docker)
# Production: leave empty to use AWS default
BEDROCK_ENDPOINT=http://localhost:4566

# Bedrock model identifiers
# Claude 3.5 Sonnet for text generation (quiz questions, DNA, paths, analytics)
CLAUDE_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Titan v2 for embeddings (1024-dimensional vectors)
TITAN_MODEL=amazon.titan-embed-text-v2:0

# ============================================
# API Configuration
# ============================================

# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
# Development: http://localhost:3000
# Production: https://vibegraph.com,https://www.vibegraph.com
CORS_ORIGINS=http://localhost:3000

# API rate limiting (requests per minute per user)
RATE_LIMIT=100

# ============================================
# Logging Configuration
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Python unbuffered output (recommended for Docker)
PYTHONUNBUFFERED=1

# Python path (for module imports)
PYTHONPATH=/app

# ============================================
# Cache Configuration
# ============================================

# Target cache hit rate for embedding generation (0.0 to 1.0)
CACHE_HIT_RATE_TARGET=0.4

# Cache TTL in seconds (default: 30 days)
CACHE_TTL=2592000

# ============================================
# Retry Configuration
# ============================================

# Claude API retry attempts
CLAUDE_RETRY_ATTEMPTS=3

# Titan API retry attempts
TITAN_RETRY_ATTEMPTS=2

# DynamoDB retry attempts
DYNAMODB_RETRY_ATTEMPTS=3

# Retry backoff base in milliseconds
RETRY_BACKOFF_BASE_MS=100

# ============================================
# Security Configuration
# ============================================

# JWT secret key (generate a secure random string for production)
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT token expiration in seconds (default: 24 hours)
JWT_EXPIRATION=86400

# ============================================
# Feature Flags
# ============================================

# Enable embedding cache
ENABLE_EMBEDDING_CACHE=true

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# Enable performance metrics
ENABLE_METRICS=true

# ============================================
# Development Configuration
# ============================================

# Enable debug mode (detailed error messages)
DEBUG=false

# Enable hot reload for development
HOT_RELOAD=true

# Mock AWS services (use LocalStack)
MOCK_AWS_SERVICES=true
